generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  role         Role      @default(USER)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  bookings      Booking[]
  conversations ChatConversation[]
  reviews       Review[]

  @@map("users")
}

model Tour {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  description         String?
  shortDescription    String?   @map("short_description")
  destination         String
  region              Region?
  duration            String
  price               Decimal   @db.Decimal(12, 2)
  discountPrice       Decimal?  @map("discount_price")
  maxParticipants     Int       @default(20) @map("max_participants")
  currentParticipants Int       @default(0) @map("current_participants")
  images              Json      @default("[]")
  highlights          Json      @default("[]")
  includes            Json      @default("[]")
  excludes            Json      @default("[]")
  schedule            Json?
  departureDates      Json      @default("[]") @map("departure_dates")
  rating              Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount         Int       @default(0) @map("review_count")
  isFeatured          Boolean   @default(false) @map("is_featured")
  isActive            Boolean   @default(true) @map("is_active")
  category            String?
  tags                Json      @default("[]")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  bookings Booking[]
  reviews  Review[]

  @@map("tours")
}

model Booking {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  tourId          String?       @map("tour_id")
  bookingCode     String        @unique @map("booking_code")
  status          BookingStatus @default(PENDING)
  numAdults       Int           @default(1) @map("num_adults")
  numChildren     Int           @default(0) @map("num_children")
  totalPrice      Decimal       @db.Decimal(12, 2) @map("total_price")
  contactName     String        @map("contact_name")
  contactEmail    String        @map("contact_email")
  contactPhone    String        @map("contact_phone")
  departureDate   DateTime?     @map("departure_date")
  specialRequests String?       @map("special_requests")
  note            String?
  paymentStatus   PaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod   String?       @map("payment_method")
  paymentDate     DateTime?     @map("payment_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  tour    Tour?   @relation(fields: [tourId], references: [id])
  review  Review?

  @@map("bookings")
}

model ChatConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id])

  @@map("chat_messages")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tourId    String   @map("tour_id")
  bookingId String?  @unique @map("booking_id")
  rating    Int
  comment   String?
  isVerified Boolean @default(false) @map("is_verified")
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  tour    Tour    @relation(fields: [tourId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

enum Role {
  USER
  ADMIN
}

enum Region {
  NORTH
  CENTRAL
  SOUTH
  INTERNATIONAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum MessageRole {
  user
  assistant
  system
}
